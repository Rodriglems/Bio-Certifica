API_PORT=3001
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=verify-full
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Separe por vírgula. Para desenvolvimento local e app mobile:
CORS_ORIGINS=http://localhost:5173,http://localhost,capacitor://localhost

# SMTP (opcional, para recuperação de senha por e-mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
EMAIL_FROM="App Agroecologia <seu_email@gmail.com>"

# Frontend (Cloudflare Pages / build local para APK)
VITE_API_BASE_URL=https://sua-api.onrender.com
